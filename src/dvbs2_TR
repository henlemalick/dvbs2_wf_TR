def cmd_rates(cfg):
    for d in ("tx", "rx"):
        s = cfg.get(d, {})
        if not s: continue
        mc = s["modcod"]; fr = s.get("frame_size","normal"); sr = float(s["symbol_rate"])
        if is_auto(mc):
            print(f"[{d}] auto @ {sr/1e6:.3f} MSym/s : low-latency | ACM/VCM | "
                  f"RX detects MODCOD per-frame from the PL header (QPSK/8PSK)")
            continue
        net = net_ts_bps(mc, fr, sr, bool(s.get("pilots", True)))
        vb = net * 0.82
        res = cfg.get("payload",{}).get("resolution","auto")
        if res == "auto": res = auto_resolution(vb)
        eng = "low-latency" if engine_for(mc)=="lowlat" else "extended (APSK)"
        tg = tier(mc); lat = latency_str(mc, sr, fr)
        print(f"[{d}] {mc} {fr} @ {sr/1e6:.3f} MSym/s : net {net/1e6:.2f} Mbps | "
              f"video ~{vb/1e6:.2f} Mbps | res {res} | mode {eng} | {tg} | latency {lat}")
        if tg == "APSK":
            print(f"     !! {mc} uses the extended engine; LATENCY ~1.5-2 s "
                  f"(acknowledged). Needs a clean/cabled link.")
        elif tg == "margin":
            print(f"     ~  {mc} is margin-dependent (runs if link margin allows; "
                  f"robust set = QPSK 1/2-2/3, 8PSK 3/5-2/3).")

def cmd_check(cfg, loopback=False):
    ok = True
    def chk(label, cond, extra=""):
        nonlocal ok; ok = ok and cond
        print(f"  [{'OK ' if cond else 'XX '}] {label}{(' - '+extra) if extra else ''}")
    print("== DVBS2_TR preflight ==" + (" (loopback)" if loopback else ""))
    chk("runtime present", os.path.isdir(ENV))
    have_py = os.path.exists(pybin())
    chk("runtime interpreter", have_py)
    #chk("transmit core", os.path.exists(app("dvbs2-tx")))
    #chk("receive core", os.path.exists(app("dvbs2-rx")))
    chk("media tool", os.path.exists(FFMPEG) or shutil.which("ffmpeg") is not None)
    # probe the runtime ONLY if its interpreter exists; never let a missing/foreign
    # runtime raise (a traceback could print source naming the backend).
    def _probe(code):
        if not have_py: return None
        try: return subprocess.run([pybin(),"-c",code], env=gr_env(), capture_output=True, text=True)
        except Exception: return None
    def _probe_any(*codes):
        """Try each probe in order; return the first that succeeds. Keeps the
        check working before and after an engine-rename pass that swaps the
        internal package names."""
        last = None
        for c in codes:
            r = _probe(c)
            if r and r.returncode == 0: return r
            last = r
        return last
    r = _probe_any("from sdrcore import link",
                   "from gnuradio import link")
    chk("modem core", bool(r) and r.returncode == 0, "" if (r and r.returncode == 0) else "not loadable")
    if loopback:
        chk("loopback OK", True, "radio probe skipped (--loopback)")
    else:
        u = _probe_any("import rf; print(len(rf.find('type=b200')))",
                       "import uhd; print(len(uhd.find('type=b200')))")
        ndev = u.stdout.strip() if u else ""
        chk("radio (B210) detected", bool(u) and u.returncode == 0 and ndev not in ("", "0"), f"{ndev} device(s)")
    # HW H.264 encoder (Jetson nvv4l2h264enc) - informational, does not gate
    # readiness. Honors [payload].encoder so an operator who picked 'sw' sees
    # an expected status instead of a scary [-- ] for a feature they didn't ask for.
    enc_sel = ((cfg.get("payload") or {}).get("encoder", "hw")).lower()
    hw = have_hw_encoder()
    if enc_sel == "sw":
        print(f"  [OK ] live video encoder = sw (libx264 via ffmpeg)"
              f"{' ; HW available but not selected' if hw else ''}")
    else:
        print(f"  [{'OK ' if hw else '-- '}] live video encoder = hw (nvv4l2h264enc) "
              f"{'present' if hw else 'not available - re-run with --encoder sw or set [payload].encoder = sw'}")
    # config rates
    try: cmd_rates(cfg); chk("config + net-rate calc", True)
    except SystemExit as e: chk("config + net-rate calc", False, str(e))
    print("== %s ==" % ("ALL GOOD - link ready" if ok else "PROBLEMS FOUND"))
    return 0 if ok else 1

def build_ffmpeg_encode(src, res, vbps, muxrate, fps):
    """ffmpeg args to encode `src` to CBR mpegts on stdout (video only).
    Tuned for low end-to-end latency in live mode (v4l2/udp/pipe): no
    B-frames, no scene-cut keyframe injection, GOP=fps (1 s keyframe
    interval), zerolatency tune, half-second rate-control buffer, no
    input buffering, flush mpegts packets immediately.

    SW-fallback path. The Jetson NVENC path is build_gst_encode below;
    dispatch is build_encode."""
    vb = f"{int(vbps/1000)}k"
    bufsz = f"{max(1, int(vbps/2/1000))}k"
    pre = [FFMPEG,"-hide_banner","-loglevel","error","-fflags","nobuffer"]
    if src.startswith("file:"):
        pre += ["-stream_loop","-1","-i",src[5:]]
    elif src.startswith("v4l2:"):
        pre += ["-f","v4l2","-framerate",str(fps),"-i",src[5:]]
    elif src.startswith("udp://") or src.startswith("pipe"):
        pre += ["-i", "pipe:0" if src=="pipe" else src]
    else:
        pre += ["-stream_loop","-1","-i",src]
    return pre + ["-an","-sn","-vf",f"scale={res},fps={fps}","-c:v","libx264",
        "-preset","ultrafast","-tune","zerolatency","-bf","0",
        "-pix_fmt","yuv420p","-b:v",vb,"-maxrate",vb,"-bufsize",bufsz,
        "-g",str(fps),"-keyint_min",str(fps),"-sc_threshold","0",
        "-x264-params","nal-hrd=cbr:force-cfr=1:no-mbtree=1",
        "-flush_packets","1",
        "-f","mpegts","-muxrate",str(int(muxrate)),
        "-mpegts_flags","+pat_pmt_at_frames",
        "pipe:1"]

def check_display_or_exit():
    """Die with a clear message if sink=display but no X display is reachable.
    ffplay silently crashes without DISPLAY, which blocks the pipeline pipe and
    causes the whole link to stall ~3 seconds in with no useful error."""
    disp = os.environ.get("DISPLAY", "")
    if disp:
        return   # DISPLAY is set — let ffplay attempt it
    sys.exit(
        "error: sink = \"display\" requires an X display, but $DISPLAY is not set.\n"
        "  This usually means you are connected via SSH without X forwarding.\n"
        "\n"
        "  Options:\n"
        "    1. Stream to another machine instead:\n"
        "         set  sink = \"udp://VIEWER_IP:1234\"  in link.toml\n"
        "         run  ffplay -fflags nobuffer -i udp://0.0.0.0:1234  on VIEWER_IP\n"
        "\n"
        "    2. Forward X over SSH (if the machine has a display):\n"
        "         ssh -X wftest@MACHINE_IP\n"
        "         then re-run dvbs2_TR\n"
        "\n"
        "    3. Run from a local terminal on the Jetson (not SSH)."
    )

_HW_ENC_CACHE = None
def have_hw_encoder():
    """True iff the Jetson HW H.264 encoder element (nvv4l2h264enc) is loadable
    on this host. Probed via gst-inspect-1.0; cached because cmd_check + cmd_tx
    + cmd_duplex all ask."""
    global _HW_ENC_CACHE
    if _HW_ENC_CACHE is not None: return _HW_ENC_CACHE
    gi = shutil.which("gst-inspect-1.0")
    if not gi: _HW_ENC_CACHE = False; return False
    try:
        r = subprocess.run([gi, "nvv4l2h264enc"], capture_output=True, text=True,
                           env=media_env(), timeout=5)
        _HW_ENC_CACHE = (r.returncode == 0)
    except Exception:
        _HW_ENC_CACHE = False
    return _HW_ENC_CACHE

def build_gst_encode(src, res, vbps, muxrate, fps):
    """Jetson HW path: GStreamer pipeline for v4l2 -> nvv4l2h264enc -> raw
    h264 on stdout, piped through ffmpeg's mpegts muxer for CBR muxrate
    padding. The two-process bash -c wrapper lets us mirror build_ffmpeg_encode's
    argv contract (stdin/stdout = pipe) so the existing _popen plumbing is
    unchanged.

    Why two stages: GStreamer's mpegtsmux doesn't accept a target muxrate -
    it packs h264 + the bare minimum nulls, producing a variable-rate TS
    that bursts at GOP boundaries. dvbs2-tx's BBFRAME assembler reads at
    the link's net rate; bursty input lets the pipe buffer up between
    keyframes and drain back, which propagates as TX timing irregularity
    and (verified on Xavier) breaks RX DEMOD after ~10 s. ffmpeg's mpegtsmux
    accepts -muxrate and pads constant-rate, which is what the link needs.

    Properties pulled from the gst-inspect probe (low-latency DVB-S2 recipe):
    control-rate=1 CBR, every-I-is-IDR, SPS/PPS+VUI+AUD inserted, UltraFast
    preset, maxperf, no B-frames, Main profile (poc-type=2 needs it).
    videoconvert+videoscale+videorate front-end so any webcam pixel format
    (YUY2/MJPEG/NV12) negotiates cleanly into nvvidconv's NVMM NV12 input."""
    gst = shutil.which("gst-launch-1.0")
    if not gst:
        raise RuntimeError("gst-launch-1.0 not found; --encoder hw needs GStreamer + the nvv4l2 plugin set")
    if not src.startswith("v4l2:"):
        raise ValueError("--encoder hw currently supports v4l2 sources only "
                         "(file: uses the preencode cache; udp:/pipe not yet HW-wired)")
    dev = src[5:]
    try: W, H = (int(x) for x in str(res).lower().split("x", 1))
    except Exception:
        raise ValueError(f"--encoder hw needs an explicit WxH resolution (got {res!r}); "
                         "set [payload].resolution = '854x480' or use --encoder sw")
    vbps = int(vbps); fps = int(fps); muxrate = int(muxrate)
    vbv = max(100000, int(vbps / max(1, fps) * 5))    # ~5-frame VBV for tight CBR
    import shlex as _sx
    gst_argv = [gst, "-q",
        "v4l2src", f"device={dev}", "!",
        "video/x-raw", "!",
        "videoconvert", "!",
        "videoscale", "!",
        "videorate", "!",
        f"video/x-raw,format=I420,width={W},height={H},framerate={fps}/1", "!",
        "nvvidconv", "!",
        "video/x-raw(memory:NVMM),format=NV12", "!",
        "nvv4l2h264enc",
        f"bitrate={vbps}", "control-rate=1",
        f"iframeinterval={fps}", f"idrinterval={fps}",
        "insert-sps-pps=true", "insert-vui=true", "insert-aud=true",
        "preset-level=1", "maxperf-enable=true",
        "num-B-Frames=0", "num-Ref-Frames=1",
        "profile=2", "poc-type=2",
        f"vbv-size={vbv}",
        "!", "h264parse", "config-interval=1",
        "!", "fdsink", "fd=1", "sync=false"]
    ff_argv = [FFMPEG, "-hide_banner", "-loglevel", "error",
        "-fflags", "nobuffer", "-f", "h264", "-i", "-",
        "-c", "copy", "-flush_packets", "1",
        "-f", "mpegts", "-muxrate", str(muxrate),
        "-mpegts_flags", "+pat_pmt_at_frames",
        "pipe:1"]
    gst_sh = " ".join(_sx.quote(x) for x in gst_argv)
    ff_sh  = " ".join(_sx.quote(x) for x in ff_argv)
    return ["bash", "-c", f"{gst_sh} | {ff_sh}"]

def build_encode(src, res, vbps, muxrate, fps, encoder):
    """Dispatch the live-source encoder per --encoder / [payload].encoder.
    'hw' = Jetson nvv4l2h264enc via gst-launch-1.0 (default on Jetson hosts);
    'sw' = libx264 via ffmpeg (portable fallback). 'hw' FAILS LOUD (raises)
    when the element is missing or the source/resolution is unsupported,
    so the operator gets one clear error instead of a silently-degraded
    link with surprise CBR behavior."""
    if encoder == "hw":
        if not have_hw_encoder():
            raise RuntimeError("--encoder hw requested but nvv4l2h264enc is not available on this host; "
                               "re-run with --encoder sw or set [payload].encoder = 'sw' in link.toml")
        return build_gst_encode(src, res, vbps, muxrate, fps)
    return build_ffmpeg_encode(src, res, vbps, muxrate, fps)

def usrp_args(cfg, d):
    # per-direction device_args (bench: two B210s) overrides [node] (deployment: one B210)
    return cfg.get(d,{}).get("device_args") or cfg.get("node",{}).get("device_args","type=b200")

def samp_type_of(cfg):
    """Over-the-wire IQ format threaded into dvbs2-tx/-rx + gr_fullduplex.py.
    sc8 halves the USB bytes/sample vs sc16 — useful when the host can't drain
    samp_rate*sps fast enough (the 'OOOO' overflow signature in the radio log)."""
    val = (cfg.get("node",{}) or {}).get("samp_type", "sc16")
    return val if val in ("sc16","sc8") else "sc16"

def raw_payload_text(cfg):
    """[raw].payload string for --raw mode. When set, rawdata_gen formats each
    frame as '<text> : <SEQ>' (padded with NUL to plen) and rawdata_rx prints
    the decoded text on every tick. The operator literally watches the counter
    increment. Empty string == legacy synthetic byte pattern (no print)."""
    return (cfg.get("raw") or {}).get("payload", "")

def low_lat_stream_args():
    """UHD host-side queue caps. send_buff_size/recv_buff_size are honored only
    by the UDP transport (X3xx/N3xx); the B210 libusb transport silently ignores
    them and sizes its URB ring by num_send_frames*send_frame_size and
    num_recv_frames*recv_frame_size. Without those keys the duplex pipeline
    ramps to ~4 s steady-state on a single B210 (libusb default ring + FX3 FIFO
    + FPGA SRAM ~= 64 MB / 16 MB/s). 8 frames * 16384 B = 128 KiB per direction
    ~= 8 ms host queue at 16 MB/s; FX3/FPGA + BBFRAME/OTA/FEC bring duplex
    steady-state into the ~250-400 ms band. Bench mode (separate TX/RX radios)
    lands lower because each libusb path carries only one direction."""
    return ("send_buff_size=2097152,recv_buff_size=2097152,"
            "num_send_frames=8,send_frame_size=16384,"
            "num_recv_frames=8,recv_frame_size=16384")

def preencode_file(srcpath, res, vb, net, fps):
    """encode a video file to a cached CBR mpegts once; return the cache path."""
    if not os.path.exists(srcpath):
        sys.exit(f"error: video source not found: {srcpath}\n"
                 f"  Drop a clip at {srcpath}, or edit [payload].source in link.toml,\n"
                 f"  or use --raw for a no-video link test.")
    vbk = f"{int(vb/1000)}k"
    cache = rp(f"dvbs2_enc_{res}_{int(vb)}_{int(net)}.ts")
    if not os.path.exists(cache):
        print(f"pre-encoding {srcpath} -> {res}@{vb/1e6:.2f}Mbps (cache) ...")
        r = subprocess.run([FFMPEG,"-hide_banner","-loglevel","error","-stream_loop","-1","-t","60",
            "-i",srcpath,"-an","-sn","-vf",f"scale={res},fps={fps}","-c:v","libx264","-preset",
            "veryfast","-pix_fmt","yuv420p","-b:v",vbk,"-maxrate",vbk,"-bufsize",vbk,"-g",str(fps),
            "-sc_threshold","0","-f","mpegts","-muxrate",str(int(net)),cache], env=media_env())
        if r.returncode != 0 or not os.path.exists(cache):
            sys.exit(f"error: ffmpeg encoding failed for {srcpath} (exit {r.returncode}).\n"
                     f"  Check the file is a valid video. Use --raw for a no-video test.")
    return cache

# ---- extended engine (APSK path) -----------------------------------------
SNAP = os.environ.get("DVBS2_APSK_HOME") or "/snap/sdrangel/current"
_TRIPLET = f"{platform.machine()}-linux-gnu"      # x86_64- / aarch64- as appropriate
# Internals of the APSK ("extended") path. The upstream package lays out files
# under <SNAP>/opt/install/<pkg>/{bin,lib}. We keep that path layout but the
# operator-facing names (functions, comments, error messages) all say
# "extended engine" — no library-identifier leaks into the driver source.
_EXT_PKG = "sdrangel"   # upstream package dir name (NOT operator-facing)
def _extended_engine_env():
    e = dict(os.environ); S = SNAP
    e["LD_LIBRARY_PATH"] = ":".join([f"{S}/opt/install/{_EXT_PKG}/lib/{_EXT_PKG}",
        f"{S}/opt/install/{_EXT_PKG}/lib", f"{S}/usr/lib/{_TRIPLET}", f"{S}/usr/lib", f"{S}/lib"])
    return e

def launch_extended_engine():
    import urllib.request
    subprocess.run(["pkill","-9","-x",f"{_EXT_PKG}srv"]); time.sleep(2)
    p = _popen([f"{SNAP}/opt/install/{_EXT_PKG}/bin/{_EXT_PKG}srv"],
               stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, env=_extended_engine_env())
    for _ in range(30):
        time.sleep(1)
        try: urllib.request.urlopen(f"http://127.0.0.1:8091/{_EXT_PKG}", timeout=2); return p
        except Exception: pass
    print("!! extended engine did not start on :8091"); return p

def extended_engine_warn(mc):
    print(f"!! {mc} is APSK -> using the extended engine (the low-latency path is QPSK/8PSK only).")
    print(f"!! WARNING: latency will be HIGH (~1.5-2 s), NOT sub-second. Proceeding (acknowledged).")

def extended_engine_run(cfg, mode, secs):
    """APSK link via the extended engine, invoked transparently (mod TX + demod RX)."""
    s = cfg["tx"]; mc = s["modcod"]; fr = s.get("frame_size","normal"); sr = float(s["symbol_rate"])
    mod, fec = sa_indices(mc)
    # find_helper looks for the file under .internal/, internal/, alongside the
    # driver, or in ../scripts. Prefers the new neutral name; the old name kept
    # as a fallback for any pre-rename bundle that's already in the field.
    ext_link = find_helper("extended_datv_link.py")
    if not os.path.exists(ext_link):
        ext_link = find_helper("sdrangel_datv_link.py")
    extended_engine_warn(mc)
    net = net_ts_bps(mc, fr, sr, bool(s.get("pilots",True))); vb = net*0.82
    pl = cfg.get("payload",{}); src = pl.get("source","file:"+os.path.join(HERE, "media", "sample.mp4"))
    res = pl.get("resolution","auto");  res = auto_resolution(vb) if res=="auto" else res
    cache = preencode_file(src[5:] if src.startswith("file:") else src, res, vb, net, int(pl.get("framerate",25)))
    dev_freq = int(float(s["freq_hz"])) - 2000000     # device freq; +2 MHz channel offset -> signal at freq_hz
    base = [pybin(), ext_link, f"symrate={int(sr)}", "samprate=8000000", f"freq={dev_freq}",
            f"modulation={mod}", f"fec={fec}", f"rfbw={int(sr*1.35)}", f"tsfile={cache}",
            f"txgain={s.get('gain_db',89)}", f"rxgain={cfg.get('rx',{}).get('gain_db',40)}",
            "rolloff=%g" % s.get("rolloff",0.35)]
    sub = {"bench":"config", "tx":"txonly", "rx":"rxonly"}[mode]
    launch_extended_engine()
    subprocess.run([base[0], base[1], sub] + base[2:], env=media_env())
    if mode == "bench":                      # full link needs an explicit start; txonly/rxonly self-run
        subprocess.run([pybin(), ext_link, "start"], env=media_env())
    if mode == "tx":
        print("APSK transmit running (Ctrl-C to stop).");
        try:
            while True: time.sleep(1)
        except KeyboardInterrupt: pass
        return
    # bench / rx: read recovered TS on udpTS:5005
    time.sleep(8)
    print(f"reading recovered TS (udpTS:5005) for {secs}s ...")
    import socket
    so = socket.socket(socket.AF_INET, socket.SOCK_DGRAM); so.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    so.bind(("0.0.0.0", cfg.get("rx",{}).get("rxudp",5005) if False else 5005)); so.settimeout(1.0)
    t0 = time.time(); last={}; cc_err=0; pkts=0; bytes_rx=0
    while time.time()-t0 < secs:
        try: d = so.recv(65536)
        except socket.timeout: continue
        bytes_rx += len(d)
        for i in range(0, len(d)-187, 188):
            if d[i]!=0x47: continue
            pid=((d[i+1]&0x1f)<<8)|d[i+2]; ccv=d[i+3]&0xf; afc=(d[i+3]>>4)&3
            if pid==0x100 and afc in (1,3):
                pkts+=1
                if pid in last and ccv!=((last[pid]+1)&0xf): cc_err+=1
                last[pid]=ccv
    mbps = bytes_rx*8/secs/1e6
    print(f">> APSK {mc}: recovered video PID 0x100 = {pkts} pkts, {cc_err} continuity errors, "
          f"{mbps:.2f} Mbps over {secs}s  (latency ~1.5-2 s, as warned)")

def _wait_radio_ready(proc, kind, max_wait=30):
    """Print a 'bringing the radio up ...' line, then wait until the modem core
    logs that it has set the master clock (meaning UHD has the device open) — or
    the process exits (failure). Returns True if ready, False if the modem core
    died early (caller should report a friendly error).

    kind = 'tx' | 'rx' | 'dx' — selects which radio log to watch.
    """
    log_path = rp({"tx":"dvbs2_tx.radio.log",
                   "rx":"dvbs2_rx.radio.log",
                   "dx":"dvbs2_dx.radio.log"}[kind])
    print(f"  [.] bringing the radio up (cold start can take up to ~10 s while the FPGA loads) ...",
          flush=True)
    t0 = time.time()
    last_dot = t0
    while proc.poll() is None and time.time() - t0 < max_wait:
        try:
            with open(log_path, "r") as f:
                text = f.read()
                if "Actually got clock rate" in text:
                    print(f"  [+] radio ready ({time.time()-t0:.1f} s) — link starting",
                          flush=True)
                    return True
        except FileNotFoundError:
            pass
        if time.time() - last_dot > 1.0:
            print("      ... still bringing it up", flush=True); last_dot = time.time()
        time.sleep(0.3)
    if proc.poll() is not None:
        print("  [x] the radio did not come up — verify the serial in link.toml matches "
              "the attached B210 and that no other process is holding the radio.")
        try:
            with open(log_path, "r") as f:
                msg = [ln for ln in f.read().splitlines()
                       if any(k in ln for k in ("Error","error","not found","Unable","Could not"))]
                for ln in msg[-3:]: print(f"      | {ln}")
        except FileNotFoundError:
            pass
        return False
    print(f"  [+] radio ready (no clock marker in {max_wait} s — proceeding anyway)", flush=True)
    return True

def tx_stats_loop(proc, cfg, mode_label, writer=None):
    """Per-second TX readout while transmitting. PLFRAME rate is deterministic at a
    fixed symbol rate; the count is elapsed-based. If `writer` is provided
    (cmd_duplex --full-stats two-column path), the line body is routed through
    it for column alignment; otherwise it prints standalone with a coloured
    [TX MM:SS] prefix."""
    s = cfg["tx"]; mc = s["modcod"]; fr = s.get("frame_size","normal"); sr = float(s["symbol_rate"])
    pil = bool(s.get("pilots", True)); pl = "pilots" if pil else "no-pilots"
    fps = frame_rate(mc, fr, sr, pil); net = net_ts_bps(mc, fr, sr, pil)
    if not _wait_radio_ready(proc, "tx"): _kill_all(); return
    t0 = writer.t0 if writer is not None else time.time()
    if writer is None:
        print(f"  TX STATS [{mc} {fr} {pl} {sr/1e6:.3f} MSym/s | {mode_label}] -- elapsed | PLFRAME rate | sent:")
    try:
        while proc.poll() is None:
            time.sleep(1.0)
            e = int(time.time()-t0)
            # 'link' = DVB-S2 link gross rate at this MODCOD/SR/frame/pilots
            # (the modulator's deterministic capacity). In --raw the actual app
            # data rate from rawdata_gen is usually a fraction of this and is
            # padded with NULL TS packets up to 'link' — the RX side's per-sec
            # Mbps reflects the app rate, not 'link'. Both numbers are correct.
            body = (f"{mc} {fr} {pl} @ {sr/1e6:.3f} MSym/s | {mode_label} | "
                    f"{fps:.0f} PLFRAME/s, {int(e*fps)} sent | link {net/1e6:.2f} Mbps")
            if writer is not None:
                writer.tx(e, body)
            else:
                el = f"{e//60:02d}:{e%60:02d}"
                print(f"  \033[1;36m[TX {el}]\033[0m {body}", flush=True)
    except KeyboardInterrupt:
        pass
    _kill_all()

def cmd_tx(cfg, raw, encoder=None, raw_udp_in=0):
    if engine_for(cfg["tx"]["modcod"]) == "extended":   # APSK -> extended engine, transparently
        return extended_engine_run(cfg, "tx", 0)
    if raw:
        tx_stats_loop(spawn_tx_raw(cfg, raw_udp_in=raw_udp_in)[-1], cfg, "raw-data"); return
    txargs, mc, fr, sr, net = tx_args(cfg)
    pl = cfg.get("payload",{}); src = pl.get("source","file:"+os.path.join(HERE, "media", "sample.mp4"))
    res = pl.get("resolution","auto"); vb = net*0.82
    if res == "auto": res = auto_resolution(vb)
    fps = int(pl.get("framerate",25))
    if src.startswith("file:"):
        cache = preencode_file(src[5:], res, vb, net, fps)
        print(f"TX video (file): {cache} -> {mc} {fr} @ {sr/1e6:.3f} MSym/s")
        cat = _popen(["cat", cache], stdout=subprocess.PIPE)
        tx = _popen(txargs,
              stdin=cat.stdout, stderr=open(rp("dvbs2_tx.radio.log"),"w"), env=gr_env())
        tx_stats_loop(tx, cfg, "video (file)"); return
    enc = (encoder or pl.get("encoder", "hw")).lower()
    print(f"TX video (live, encoder={enc}): {src} -> {res}@{vb/1e6:.2f}Mbps -> {mc} {fr} @ {sr/1e6:.3f} MSym/s")
    ff = _popen(build_encode(src,res,vb,net,fps,enc),
          stdout=subprocess.PIPE, stderr=open(rp("dvbs2_tx.enc.log"),"w"), env=media_env())
    tx = _popen(txargs,
          stdin=ff.stdout, stderr=open(rp("dvbs2_tx.radio.log"),"w"), env=gr_env())
    tx_stats_loop(tx, cfg, "video (live)")

def poll_full_stats(port, cfg, proc, writer=None, loopback=False, skip_radio_wait=False):
    """Poll dvbs2-rx --mon-server JSON once/second -> rich receiver line. Polls on a
    timer (independent of TS flow) so it ALWAYS ticks - including during a signal
    drop - with elapsed time. SNR(Es/N0), CFO, LDPC iters, FER are exported; symbol-
    timing & phase offset are internal to the receiver and not exported.

    'DEMOD' replaces the previous 'LOCK' label so the green tag here does not
    collide with the green 'VIDEO' tag printed by ts_tee_stats.py (separate
    concepts: PHY sync vs. TS bytes flowing). When `writer` is provided this
    routes the line body through it for two-column duplex alignment."""
    import urllib.request
    opener = urllib.request.build_opener(urllib.request.ProxyHandler({}))  # never proxy localhost
    s = cfg["rx"]; mc = s["modcod"]; fr = s.get("frame_size","normal"); sr = float(s["symbol_rate"])
    pilots = bool(s.get("pilots", True))
    auto = is_auto(mc)
    # Expected TS packets/sec for every candidate MODCOD the low-latency path can lock
    # to (QPSK/8PSK on this symrate/frame/pilots config). Used (a) to label the
    # detected MODCOD when -m auto is in force, and (b) to flag a MODCOD mismatch
    # when the operator launched RX with a concrete -m that no longer matches the
    # TX (LDPC stuck at the ceiling, FER ~100%, zero TS recovered).
    _CAND_MC = ("QPSK1/2","QPSK3/5","QPSK2/3","QPSK3/4","QPSK4/5","QPSK5/6","QPSK8/9",
                "8PSK3/5","8PSK2/3","8PSK3/4","8PSK5/6","8PSK8/9")
    expect_tp = {}
    for _cmc in _CAND_MC:
        try:
            expect_tp[_cmc] = net_ts_bps(_cmc, fr, sr, pilots) / (188 * 8)
        except SystemExit:
            pass
    # The duplex path writes to dx.radio.log, plain RX to rx.radio.log; pick by sniffing the cfg.
    kind = "dx" if (cfg.get("tx") and cfg.get("rx") and
                    cfg["tx"].get("freq_hz") != cfg["rx"].get("freq_hz")) else "rx"
    if loopback:
        print("  [+] loopback — no radio init, flowgraph starts immediately", flush=True)
    elif not skip_radio_wait and not _wait_radio_ready(proc, kind):
        _kill_all(); return
    # Track USB host-buffer overflows: UHD writes an 'O' to its log every time
    # the host couldn't drain a sample in time. We tail the relevant radio log
    # between ticks and surface the count on the per-second line so the
    # operator sees it without grep'ing — overflow bursts directly cause
    # symbol loss → "lock break" with no obvious cause in the JSON metrics.
    _of_log = rp({"rx":"dvbs2_rx.radio.log","dx":"dvbs2_dx.radio.log"}[kind])
    _of_pos = 0
    _of_total = 0
    try:
        # Seek to end at the start so we don't count pre-existing overflows
        # from the init phase.
        with open(_of_log, "rb") as _fl: _fl.seek(0, 2); _of_pos = _fl.tell()
    except FileNotFoundError:
        pass
    t0 = writer.t0 if writer is not None else time.time()
    if writer is None:
        print(f"  RX FULL STATS [{mc} {fr} {sr/1e6:.3f} MSym/s] -- elapsed | demod | SNR(Es/N0) | CFO | "
              f"LDPC iters | FER | TS  (ticks every 1 s):")
    prev_f = prev_e = prev_p = 0
    def _emit_rx(e, body, raw_only=False):
        """Route an RX-side body through the writer when present, else print
        with the coloured prefix inline."""
        if writer is not None:
            writer.rx(e, body)
        else:
            el = f"{e//60:02d}:{e%60:02d}"
            print(f"  \033[1;34m[RX {el}]\033[0m {body}", flush=True)
    try:
        while proc.poll() is None:
            time.sleep(1.0)
            e = int(time.time()-t0)
            try:
                j = json.loads(opener.open(f"http://127.0.0.1:{port}/", timeout=2.5).read())
            except Exception:
                _emit_rx(e, f"{mc} {fr} | (waiting for receiver monitor ...)"); continue
            pl = j.get("plsync") or {}; fec = j.get("fec") or {}; tsd = j.get("mpeg-ts") or {}
            cfo = pl.get("freq_offset_hz")
            if not j.get("lock"):
                cs = f" | CFO {cfo/1e3:+.1f} kHz" if cfo is not None else ""
                _emit_rx(e, f"{mc} {fr} | \033[1;31mNO DEMOD\033[0m (searching){cs}"); continue
            snr = j.get("snr"); it = fec.get("avg_ldpc_trials")
            f = fec.get("frames") or 0; ee = fec.get("errors") or 0; tp = tsd.get("packets") or 0
            df = f - prev_f; de = ee - prev_e; dtp = tp - prev_p; prev_f, prev_e, prev_p = f, ee, tp
            ifer = (de / df * 100) if df > 0 else 0.0          # per-second (instantaneous) FER
            snr_s = f"{snr:4.1f} dB" if snr is not None else "  ?  "
            cfo_s = f"{cfo/1e3:+.1f} kHz" if cfo is not None else "?"
            it_s  = f"{it:.1f}" if it is not None else "?"
            # --- MODCOD label + mismatch detection ----------------------------
            # In -m auto (ACM/VCM) mode we don't know which MODCOD the demod has
            # actually locked onto, but the recovered TS rate uniquely identifies
            # it (each MODCOD has a distinct net TS bitrate at a fixed symrate/
            # frame/pilots). Compare against the pre-built table.
            mc_label = mc
            auto_matched = False
            if auto and dtp > 50 and expect_tp:
                _bmc, _btp = min(expect_tp.items(), key=lambda kv: abs(dtp - kv[1]))
                if _btp > 0 and abs(dtp - _btp) / _btp <= 0.05:
                    mc_label = f"auto -> {_bmc}"
                    auto_matched = True
                else:
                    mc_label = "auto(?)"
            # Mismatch = receiver clearly trying but failing to decode (LDPC pinned
            # at the iteration ceiling, near-100% FER, no TS coming out) OR auto
            # mode is seeing TS at a rate that matches no candidate within 10%.
            mismatch = False
            if (it is not None and it >= 24 and ifer > 50.0 and dtp < 50):
                mismatch = True
            elif auto and dtp > 50 and expect_tp:
                _bmc2, _btp2 = min(expect_tp.items(), key=lambda kv: abs(dtp - kv[1]))
                if _btp2 <= 0 or abs(dtp - _btp2) / _btp2 > 0.10:
                    mismatch = True
            # Read any new bytes appended to the radio log and count 'O' marks.
            of_delta = 0
            try:
                with open(_of_log, "rb") as _fl:
                    _fl.seek(_of_pos)
                    _new = _fl.read()
                    _of_pos = _fl.tell()
                of_delta = _new.count(b"O")
            except FileNotFoundError:
                pass
            _of_total += of_delta
            of_tag = f" | \033[1;33mUSB OF +{of_delta} (sum {_of_total})\033[0m" if of_delta else ""
            _emit_rx(e, f"{mc_label} {fr} | \033[1;32mDEMOD\033[0m | SNR(Es/N0) {snr_s} | CFO {cfo_s} | "
                        f"LDPC {it_s} it/frm | FER {ifer:5.2f}%/s | {df} frm/s, {dtp} TS pkt/s{of_tag}")
            if mismatch:
                _emit_rx(e, "[!] MODCOD mismatch suspected (LDPC at ceiling, FER ~100%, 0 TS)."
                            " The TX MODCOD likely changed since RX started. Re-run RX with"
                            " '-m auto' OR restart with the matching -m <MODCOD>.")
            if of_delta > 5:
                # First-line fix is sc8: halves wire bytes / sample, ENOB drop
                # is negligible for DVB-S2 at typical lock SNRs (>5 dB margin).
                # Second is to drop RX oversample (and the lo_offset_hz with it).
                # Third is to max out clocks/fan on the Jetson if you have sudo.
                _emit_rx(e, "[!] USB host-buffer overflows: host can't drain samples in time.")
                _emit_rx(e, '    Edit link.toml: [node] samp_type = "sc8"  (halves wire bytes)')
                _emit_rx(e, "    OR: drop [rx] oversample 4 -> 2 (also halve lo_offset_hz)")
                _emit_rx(e, "    AND/OR: 'sudo jetson_clocks' on the Jetson if you can")
    except KeyboardInterrupt:
        raise                                # let the supervisor / main stop cleanly

def cmd_rx(cfg, raw, full_stats=False, raw_udp_out=""):
    if engine_for(cfg["rx"]["modcod"]) == "extended":   # APSK -> extended engine, transparently
        return extended_engine_run(cfg, "rx", 10**9)
    s = cfg["rx"]; fr = s.get("frame_size","normal")
    sr = float(s["symbol_rate"]); sps = int(s.get("oversample",4)); loff = float(s.get("lo_offset_hz", 2e6))
    auto = is_auto(s["modcod"])                       # ACM/VCM: detect MODCOD per-frame
    mc_app = "QPSK1/2" if auto else modcod_for_app(s["modcod"])   # placeholder for ACM init
    mc = "auto(ACM)" if auto else mc_app              # display label
    pilots = "auto" if auto else ("on" if s.get("pilots",True) else "off")
    serial = _resolve_serial(cfg, "rx")
    rxargs = [pybin(), find_helper("gr_rxonly.py"),
              "--modcod", mc_app, "--sym-rate", str(int(sr)), "--sps", str(sps),
              "--frame-size", fr, "--rolloff", str(s.get("rolloff",0.35)),
              "--rx-gain", str(s.get("gain_db",40)),
              "--rx-antenna", s.get("antenna","RX2"),
              "--rx-freq", str(int(float(s["freq_hz"]))),
              "--lo-offset", str(int(loff)),
              "--otw-format", samp_type_of(cfg),
              "--stream-args", low_lat_stream_args(),
              "--out-fd", "1",
              "--ldpc-iterations", str(cfg.get("fec",{}).get("ldpc_iters",25))]
    if serial: rxargs += ["--serial", serial]
    if pilots != "off": rxargs += ["--pilots", pilots]
    if auto: rxargs += ["--pl-acm-vcm"]               # accept all MODCODs; detect from PL header
    if full_stats: rxargs += ["--mon-server","--mon-port",str(MONPORT)]
    env = media_env()
    rxcmd = "'"+pybin()+"' " + " ".join(f"'{a}'" for a in rxargs)
    UHD = f"2>{rp('dvbs2_rx.radio.log')}"
    if raw:
        print(f"RX raw-data readout: {mc} {fr} @ {sr/1e6:.3f} MSym/s"
              + (f"  | UDP-out {raw_udp_out}" if raw_udp_out else ""))
        import shlex
        pt = raw_payload_text(cfg)
        pt_arg = f" --payload-text {shlex.quote(pt)}" if pt else ""
        udp_out_arg = f" --udp-out {shlex.quote(raw_udp_out)}" if raw_udp_out else ""
        rx_verbose_arg = " --verbose" if full_stats else ""
        sh = (rxcmd + f" {UHD} | "
              f"'{pybin()}' '{find_helper('rawdata_rx.py')}' --stdin "
              f"--pid 0x100 --plen 200 --rate 600000 --modcod '{mc}' --symrate {int(sr)} "
              f"--freq {int(float(s['freq_hz']))} --mode 'DVBS2_TR link'{pt_arg}{udp_out_arg}{rx_verbose_arg}")
        _wait([_popen(["bash","-c",sh], env=env)]); return
    pl = cfg.get("payload",{}); sink = pl.get("sink","file:/tmp/dvbs2_rx.ts")
    if sink == "display": check_display_or_exit()
    net_bps = net_ts_bps(s["modcod"], fr, sr, bool(s.get("pilots", True)))
    def consumer():                          # consumes the TS on stdin into the sink
        if sink == "display":         return f"| '{pybin()}' '{find_helper('ts_smooth.py')}' --bitrate {int(net_bps)} | '{FFPLAY}' -loglevel error -fflags nobuffer -flags low_delay -i - 2>/tmp/dvbs2_sink.log"
        if sink.startswith("udp://"):
            u = sink + ("&" if "?" in sink else "?") + "pkt_size=1316"
            return f"| '{FFMPEG}' -hide_banner -loglevel error -fflags +nobuffer -probesize 32 -analyzeduration 0 -f mpegts -i - -c copy -flush_packets 1 -f mpegts '{u}' 2>/tmp/dvbs2_sink.log"
        return f"> '{sink[5:] if sink.startswith('file:') else '/tmp/dvbs2_rx.ts'}'"
    if full_stats:
        if sink.startswith("file:"):
            tail = f"{UHD} > '{sink[5:]}'"
        else:
            tail = f"{UHD} " + consumer()
        print(f"RX video -> {sink} (FULL STATS): {mc} {fr} @ {sr/1e6:.3f} MSym/s")
        spawn = lambda: _popen(["bash","-c", rxcmd + " " + tail], env=env)
        if auto:
            _supervise_rx(mc, spawn, lambda p: poll_full_stats(MONPORT, cfg, p))
        else:
            poll_full_stats(MONPORT, cfg, spawn())
        return
    tee = (f"| '{pybin()}' '{find_helper('ts_tee_stats.py')}' --pid auto "
           f"--modcod '{mc}' --frame '{fr}' --symrate {int(sr)}")
    sh = rxcmd + f" {UHD} " + tee + " " + consumer()
    print(f"RX video -> {sink}: {mc} {fr} @ {sr/1e6:.3f} MSym/s  (live stats below)")
    spawn = lambda: _popen(["bash","-c",sh], env=env)
    if auto: _supervise_rx(mc, spawn)
    else: _wait([spawn()])

