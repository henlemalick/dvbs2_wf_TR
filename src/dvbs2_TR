# ---- stats writer: two-column or interleaved coloured prefixes ---------------
# When the terminal is wide enough, the duplex --full-stats view renders TX on
# the left, RX on the right, separated by "||". When narrower (or running
# outside a tty, e.g. piped to a log), each side just prints on its own line
# with a coloured prefix so the operator can still tell them apart at a glance.
_TWOCOL_MIN_W = 160
_ANSI_RE = re.compile(r"\x1b\[[0-9;]*m")
def _ansi_len(s): return len(_ANSI_RE.sub("", s))

class _StatsWriter:
    """Coordinate TX and RX per-second lines. Thread-safe.

    Each side calls writer.tx(sec, body) / writer.rx(sec, body) where `sec` is
    elapsed-seconds-since-start (int) and `body` is the line body WITHOUT a
    leading prefix (the writer adds a coloured [TX MM:SS] / [RX MM:SS] itself
    so both sides share the same alignment).

    In two-column mode the writer holds each side's line briefly until the
    other side fills the same second (or 1.5 s elapse with one side missing).
    """
    def __init__(self):
        self.t0 = time.time()
        try: self.w = shutil.get_terminal_size((100, 24)).columns
        except Exception: self.w = 100
        self.two_col = self.w >= _TWOCOL_MIN_W and sys.stdout.isatty()
        self.half = max(60, (self.w - 4) // 2) if self.two_col else self.w
        self.buf = {}              # sec -> {'tx': str, 'rx': str}
        self.lock = threading.Lock()
        self.stop_event = threading.Event()
        self.flush_thread = None
        if self.two_col:
            t = threading.Thread(target=self._flusher, daemon=True)
            t.start(); self.flush_thread = t

    def _prefix(self, side, sec):
        el = f"{sec//60:02d}:{sec%60:02d}"
        # cyan TX, blue RX
        col = "\033[1;36m" if side == "tx" else "\033[1;34m"
        tag = "TX" if side == "tx" else "RX"
        return f"{col}[{tag} {el}]\033[0m"

    def _emit(self, sec, tx_body, rx_body):
        tx = (self._prefix("tx", sec) + " " + tx_body) if tx_body else ""
        rx = (self._prefix("rx", sec) + " " + rx_body) if rx_body else ""
        if self.two_col:
            tx_pad = max(0, self.half - _ansi_len(tx))
            rx_pad = max(0, self.half - _ansi_len(rx))
            print(f"{tx}{' ' * tx_pad} || {rx}{' ' * rx_pad}", flush=True)
        else:
            if tx: print(tx, flush=True)
            if rx: print(rx, flush=True)

    def _flusher(self):
        # Periodically sweep for half-rows whose other side never arrived.
        while not self.stop_event.is_set():
            self.stop_event.wait(0.4)
            if self.stop_event.is_set(): break
            now_sec = int(time.time() - self.t0)
            with self.lock:
                for k in sorted(list(self.buf.keys())):
                    if now_sec - k > 1:
                        entry = self.buf.pop(k)
                        self._emit(k, entry.get("tx"), entry.get("rx"))

    def write(self, side, sec, body):
        with self.lock:
            entry = self.buf.setdefault(sec, {})
            entry[side] = body
            if "tx" in entry and "rx" in entry:
                self._emit(sec, entry.get("tx"), entry.get("rx"))
                del self.buf[sec]

    def tx(self, sec, body): self.write("tx", sec, body)
    def rx(self, sec, body): self.write("rx", sec, body)

    def close(self):
        self.stop_event.set()
        with self.lock:
            for k in sorted(self.buf.keys()):
                entry = self.buf[k]
                self._emit(k, entry.get("tx"), entry.get("rx"))
            self.buf.clear()

# ---- child-process management (clean shutdown stops the radios) --------------
import atexit
_PROCS = []
def _popen(*a, **k):
    k.setdefault("start_new_session", True)   # own process group -> clean group-kill
    p = subprocess.Popen(*a, **k); _PROCS.append(p); return p
def _reg(p): _PROCS.append(p); return p
def _killgrp(p, sig):
    try: os.killpg(os.getpgid(p.pid), sig)
    except BaseException:
        try: p.send_signal(sig)
        except BaseException: pass
def _kill_all():
    for p in _PROCS:
        if p.poll() is None: _killgrp(p, signal.SIGINT)
    for p in _PROCS:
        try: p.wait(timeout=3)
        except BaseException: _killgrp(p, signal.SIGKILL)
    # Belt-and-braces: any pipeline child that escaped its process group
    # (bash `while :; do cat ...`, ts_tee_stats, gr_fullduplex, dvbs2-rx/-tx,
    # ffmpeg) must NOT outlive the driver. Sweep by name. -P own-pid so we
    # never kill ourselves.
    own = os.getpid()
    for name in ("ts_tee_stats.py","gr_fullduplex.py","rawdata_rx.py",
                 "rawdata_gen.py","dvbs2-rx","dvbs2-tx"):
        try:
            subprocess.run(["pkill","-9","-f",name],
                           stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                           timeout=2)
        except BaseException:
            pass
atexit.register(_kill_all)
exiting = False
def _sigint(*a):
    global exiting
    if not exiting:
        exiting = True
        sys.exit(0)

atexit.register(_kill_all)
signal.signal(signal.SIGTERM, _sigint)
signal.signal(signal.SIGINT,  _sigint)
                                                        # is raised inside a C-extension)

def _resolve_serial(cfg, direction):
    """Extract B210 serial from config device_args, or probe UHD for one."""
    da = usrp_args(cfg, direction)
    m = re.search(r"serial=([0-9A-Za-z]+)", da)
    if m: return m.group(1)
    try:
        probe = subprocess.run(
            [pybin(), "-c", "import uhd,sys; ds=uhd.find('type=b200'); "
             "print(ds[0]['serial']) if ds else sys.exit(2)"],
            env=gr_env(), capture_output=True, text=True, timeout=8)
        if probe.returncode == 0 and probe.stdout.strip():
            return probe.stdout.strip()
    except Exception:
        pass
    return ""

def tx_args(cfg):
    s = cfg["tx"]; mc = modcod_for_app(s["modcod"]); fr = s.get("frame_size","normal")
    sr = float(s["symbol_rate"]); sps = int(s.get("oversample",2))
    net = net_ts_bps(s["modcod"], fr, sr, bool(s.get("pilots",True)))
    serial = _resolve_serial(cfg, "tx")
    a = [pybin(), find_helper("gr_txonly.py"),
         "--modcod", mc, "--sym-rate", str(int(sr)), "--sps", str(sps),
         "--rolloff", str(s.get("rolloff",0.35)), "--frame-size", fr,
         "--tx-gain", str(s.get("gain_db",70)),
         "--tx-antenna", s.get("antenna","TX/RX"),
         "--tx-freq", str(int(float(s["freq_hz"]))),
         "--otw-format", samp_type_of(cfg),
         "--stream-args", low_lat_stream_args(),
         "--in-fd", "0"]
    if serial: a += ["--serial", serial]
    if s.get("pilots",True): a += ["--pilots", "on"]
    else: a += ["--pilots", "off"]
    return a, mc, fr, sr, net

def spawn_tx_raw(cfg, raw_udp_in=0):
    txargs, mc, fr, sr, net = tx_args(cfg); env = gr_env()
    print(f"TX raw-data: {mc} {fr} @ {sr/1e6:.3f} MSym/s (net {net/1e6:.2f} Mbps)"
          + (f"  | UDP-in :{raw_udp_in}" if raw_udp_in else ""))
    gen_args = [pybin(), find_helper("rawdata_gen.py"),
                "--plen","200","--datarate","600000","--netrate",str(int(sr)),"--pid","0x100"]
    pt = raw_payload_text(cfg)
    if pt: gen_args += ["--payload-text", pt]
    if raw_udp_in: gen_args += ["--udp-in", str(raw_udp_in)]
    _gen_err = sys.stderr if raw_udp_in else subprocess.DEVNULL
    gen = _popen(gen_args,
          stdout=subprocess.PIPE, stderr=_gen_err, env=env)
    tx = _popen(txargs,
          stdin=gen.stdout, stderr=open(rp("dvbs2_tx.radio.log"),"w"), env=env)
    return [gen, tx]

