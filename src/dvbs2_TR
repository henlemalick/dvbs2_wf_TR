# When frozen by PyInstaller, __file__ points at sys._MEIPASS (the temp
# extraction tree — where bundled helpers live). The OPERATOR'S bundle dir is
# the directory of the executable itself; that's where link.toml + media/ +
# a per-bundle .engine/ (when present) live.
if getattr(sys, "frozen", False):
    HERE = os.path.dirname(os.path.abspath(sys.executable))
else:
    HERE = os.path.dirname(os.path.abspath(__file__))
# Self-contained bundle runs from HERE/runtime — or HERE/.engine, HERE/engine,
# HERE/.runtime when the operator wants the engine hidden / renamed; ALSO
# accepts a system-installed engine at /usr/local/lib/dvbs2_TR_engine when the
# operator station was provisioned via the .deb package; falls back to a
# legacy path, or an explicit DVBS2_ENV override.
_SYSTEM_ENGINE = "/usr/local/lib/.engine"
def _pick_env():
    if os.environ.get("DVBS2_ENV"): return os.environ["DVBS2_ENV"]
    # PyInstaller / system-install:  /usr/local/lib/dvbs2_TR_engine wins
    # when there is no per-bundle directory at HERE — that's the .deb
    # path where the operator station ships only dvbs2_TR + link.toml + media.
    for d in (".engine", "engine", ".runtime", "runtime"):
        p = os.path.join(HERE, d)
        if os.path.isdir(p): return p
    if os.path.isdir(_SYSTEM_ENGINE): return _SYSTEM_ENGINE
    return os.path.expanduser("~/wfhss_deploy/env")
ENV = _pick_env()
RUNDIR = os.environ.get("DVBS2_RUNDIR") or "/tmp"          # scratch dir: logs/cache/sink
def rp(name): return os.path.join(RUNDIR, name)
