def find_helper(name):
    """Locate a helper script. Search order:
       0) PyInstaller's runtime extraction dir (sys._MEIPASS), when the driver
          is running as a frozen single-file binary,
       1) the operator-hidden internal/ dir alongside the driver (minimal layout),
       2) flat alongside the driver (legacy layout),
       3) /usr/local/lib/dvbs2_TR/ (system .deb install — script-mode driver),
       4) the repo's ../scripts (dev mode)."""
    meipass = getattr(sys, "_MEIPASS", None)
    if meipass:
        p = os.path.join(meipass, name)
        if os.path.exists(p): return os.path.abspath(p)
    for p in (os.path.join(HERE, ".internal", name),
              os.path.join(HERE, "internal", name),
              os.path.join(HERE, name),
              os.path.join(_SYSTEM_HELPERS, name),
              os.path.join(HERE, "..", "scripts", name)):
        if os.path.exists(p): return os.path.abspath(p)
    return os.path.join(HERE, name)

def default_config():
    """Find link.toml without --config. Search order, first hit wins:
      1. ./link.toml (CWD) - the deployed station case: operator cd's into
         ~/DVBS2_TR_Deployed and types `dvbs2_TR check`.
      2. <bundle_dir>/link.toml - the per-bundle case: dev tree where
         dvbs2_TR + link.toml live next to each other.
      3. <bundle_dir>/../config/link.toml - the repo case.
      4. fallback: <bundle_dir>/link.toml so the error message still names
         a sensible path."""
    cwd = os.path.abspath(os.getcwd())
    for p in (os.path.join(cwd, "link.toml"),
              os.path.join(HERE, "link.toml"),
              os.path.join(HERE, "..", "config", "link.toml")):
        if os.path.exists(p): return os.path.abspath(p)
    return os.path.join(HERE, "link.toml")

# ---- DVB-S2 FEC parameters (BCH Kbch per code rate; ETSI EN 302 307-1) -------
NLDPC = {"normal": 64800, "short": 16200}
KBCH = {
    "normal": {"1/4":16008,"1/3":21408,"2/5":25728,"1/2":32208,"3/5":38688,
               "2/3":43040,"3/4":48408,"4/5":51648,"5/6":53840,"8/9":57472,"9/10":58192},
    "short":  {"1/4":3072,"1/3":5232,"2/5":6312,"1/2":7032,"3/5":9552,
               "2/3":10632,"3/4":11712,"4/5":12432,"5/6":13152,"8/9":14232},
}
MODBITS = {"QPSK":2, "8PSK":3, "16APSK":4, "32APSK":5}
BBHEADER_BITS = 80

def pl_symbols(modcod, frame, pilots):
    """Total symbols per PLFRAME (payload + PLHEADER + pilots)."""
    mod, _ = parse_modcod(modcod)
    n_data = NLDPC[frame] // MODBITS[mod]            # payload symbols / PLFRAME
    n_slots = n_data // 90
    n_pilot_blocks = max(0, (n_slots - 1) // 16) if pilots else 0
    return n_data + 90 + 36 * n_pilot_blocks         # +PLHEADER(90)

def frame_rate(modcod, frame, symrate, pilots):
    """PLFRAMEs transmitted per second (deterministic at a fixed symbol rate)."""
    return symrate / pl_symbols(modcod, frame, pilots)

def net_ts_bps(modcod, frame, symrate, pilots):
    """Exact DVB-S2 useful TS bitrate for a MODCOD/frame/symrate (pilots-aware)."""
    mod, rate = parse_modcod(modcod)
    if frame not in KBCH or rate not in KBCH[frame]:
        raise SystemExit(f"unsupported MODCOD/frame: {modcod} {frame}")
    return (KBCH[frame][rate] - BBHEADER_BITS) * frame_rate(modcod, frame, symrate, pilots)

def parse_modcod(s):
    s = s.replace("_", "")                       # QPSK_3/5 -> QPSK3/5
    m = re.match(r"(QPSK|8PSK|16APSK|32APSK)(\d+/\d+)$", s)
    if not m: raise SystemExit(f"bad MODCOD '{s}'")
    return m.group(1), m.group(2)

def modcod_for_app(s):                           # link.toml 'QPSK_3/5' -> app '-m QPSK3/5'
    mod, rate = parse_modcod(s); return mod + rate

# ---- engine routing (internal) --------------------------------------------
# QPSK/8PSK use the low-latency path (sub-second). 16/32APSK use the extended
# path (higher latency); both run transparently behind the same CLI.
SA_MOD = {"QPSK":1, "8PSK":2, "16APSK":3, "32APSK":4}          # extended-engine modulation idx
SA_FEC = {"1/2":0,"2/3":1,"3/4":2,"5/6":3,"7/8":4,"4/5":5,     # extended-engine code-rate idx
          "8/9":6,"9/10":7,"1/4":8,"1/3":9,"2/5":10,"3/5":11}
# Reliably-smooth on the antenna link (docs/LINK_HARDENING.md). Others run but
# depend on link margin (clean/cabled link).
ROBUST = {("QPSK","1/2"),("QPSK","3/5"),("QPSK","2/3"),("8PSK","3/5"),("8PSK","2/3")}

def is_auto(modcod): return str(modcod).lower() == "auto"   # RX ACM/VCM auto-detect

def engine_for(modcod):
    if is_auto(modcod): return "lowlat"         # ACM auto-detect, low-latency path (QPSK/8PSK)
    mod, _ = parse_modcod(modcod)
    return "extended" if mod in ("16APSK","32APSK") else "lowlat"

def tier(modcod):
    if is_auto(modcod): return "auto"
    mod, rate = parse_modcod(modcod)
    if mod in ("16APSK","32APSK"): return "APSK"
    return "robust" if (mod, rate) in ROBUST else "margin"

def latency_str(modcod, sr, frame):
    if engine_for(modcod) == "extended": return "~1.5-2 s"
    base = 1.54e6 / sr                          # ~0.77 s @ 2 MSym/s short (measured)
    if frame == "normal": base *= 3.5
    return f"~{base:.2f} s"

def sa_indices(modcod):
    mod, rate = parse_modcod(modcod)
    return SA_MOD[mod], SA_FEC[rate]

# ---- resolution ladder (auto-scale video to the net rate) --------------------
def auto_resolution(video_bps):
    mbps = video_bps / 1e6
    for thr, res in [(0.5,"480x270"),(1.0,"640x360"),(1.8,"640x360"),
                     (3.0,"854x480"),(5.0,"1280x720")]:
        if mbps < thr: return res
    return "1280x720"

# ---- minimal TOML reader (flat key=val within [sections]; enough for link.toml)
def load_toml(path):
    cfg, sec = {}, None
    for ln in open(path):
        ln = ln.split("#", 1)[0].strip()
        if not ln: continue
        if ln.startswith("[") and ln.endswith("]"):
            sec = ln[1:-1].strip(); cfg[sec] = {}; continue
        if "=" in ln and sec is not None:
            k, v = (x.strip() for x in ln.split("=", 1))
            cfg[sec][k] = _coerce(v)
    return cfg

def _coerce(v):
    if v.startswith('"') and v.endswith('"'): return v[1:-1]
    if v in ("true","false"): return v == "true"
    try:
        f = float(v); return int(f) if f.is_integer() and "e" not in v.lower() and "." not in v else f
    except ValueError:
        return v

