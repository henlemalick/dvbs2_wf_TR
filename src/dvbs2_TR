    s = cfg["rx"]; mc = modcod_for_app(s["modcod"]); fr = s.get("frame_size","normal")
    sr = float(s["symbol_rate"]); sps = int(s.get("oversample",4))
    loff = float(s.get("lo_offset_hz", 2e6))
