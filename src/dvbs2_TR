def _pick_images():
    """Radio firmware images live under share/<X>/images. Original layout used
    'uhd'; the post-rebrand layout renames it to 'radio'. Pick whichever
    actually exists so the same driver works before AND after the rebrand."""
    for sub in ("radio", "uhd"):
        p = os.path.join(ENV, "share", sub, "images")
        if os.path.isdir(p): return p
    return os.path.join(ENV, "share", "uhd", "images")  # last-resort default
IMAGES = _pick_images()                                   # bundled radio images (offline)
# media tool: prefer a system ffmpeg/ffplay; else fall back to the one inside the
# runtime, run via media_env (no runtime LD_LIBRARY_PATH) so it resolves its own
# libs by RPATH and is not crippled. Keeps the bundle self-contained, no system pkg.
FFMPEG = shutil.which("ffmpeg") or os.path.join(ENV, "bin", "ffmpeg")
