          f"--mode 'DVBS2_TR self-test'{pt_arg}{udp_out_arg}\"")
    subprocess.run(["bash","-c",sh], env=media_env())
    _kill_all()

def cmd_duplex(cfg, raw, full_stats, secs, encoder=None, loopback=False,
               raw_udp_in=0, raw_udp_out=""):
    """FULL DUPLEX on ONE B210: transmit @[tx].freq_hz AND receive @[rx].freq_hz
    simultaneously, in one combined modulate+demodulate flowgraph (fullduplex
    helper). Each deployed node runs one of these; on the bench run it on each
    B210 with the freq plan swapped for a bidirectional link.

    --loopback: tell gr_fullduplex.py to skip the USRP and self-loop the TX
    samples into the RX path inside the flowgraph."""
    t = cfg["tx"]; r = cfg.get("rx", {})
    if is_auto(t["modcod"]): sys.exit("duplex TX needs a concrete MODCOD ('auto' is RX-only).")
    mc = modcod_for_app(t["modcod"]); fr = t.get("frame_size","normal"); sr = float(t["symbol_rate"])
    sps = int(t.get("oversample",2)); pil = "on" if t.get("pilots",True) else "off"
    txf = int(float(t["freq_hz"])); rxf = int(float(r.get("freq_hz", t["freq_hz"])))
    da = usrp_args(cfg,"tx"); m = re.search(r"serial=([0-9A-Za-z]+)", da)
    serial = m.group(1) if m else ""
    if serial in ("", "0", "any"):
        # No explicit serial in link.toml — query UHD for the first attached B210
        # so the duplex helper doesn't get serial=0 (which never matches).
        try:
            probe = subprocess.run(
                [pybin(),"-c","import uhd,sys; ds=uhd.find('type=b200'); "
                 "print(ds[0]['serial']) if ds else sys.exit(2)"],
                env=gr_env(), capture_output=True, text=True, timeout=8)
            if probe.returncode == 0 and probe.stdout.strip():
                serial = probe.stdout.strip()
        except Exception:
            pass
    fd = find_helper("gr_fullduplex.py")
    import shlex as _sx
    fdargs = (f"--serial {serial or 'any'} --tx-freq {txf} --rx-offset-hz {rxf-txf} --sym-rate {int(sr)} "
              f"--modcod {mc} --frame-size {fr} --sps {sps} --tx-gain {t.get('gain_db',89)} "
              f"--rx-gain {r.get('gain_db',40)} --tx-antenna {t.get('antenna','TX/RX')} "
              f"--rx-antenna {r.get('antenna','RX2')} --pilots {pil} --rolloff {t.get('rolloff',0.35)} "
              f"--otw-format {samp_type_of(cfg)} "
              f"--stream-args {_sx.quote(low_lat_stream_args())} "
              f"--in-fd 0 --out-fd 3")
    if full_stats: fdargs += f" --mon-server --mon-port {MONPORT}"
    if loopback:   fdargs += " --loopback"
    fdcmd = gr_shell_prefix() + f"'{pybin()}' '{fd}' " + fdargs
    UHD = f"2>>{rp('dvbs2_dx.radio.log')}" if loopback else f"2>{rp('dvbs2_dx.radio.log')}"
    if loopback:
        print(f"DUPLEX (loopback, no radio): TX {mc} {fr} @ {txf/1e6:.1f} MHz nominal  +  RX self-loop "
              f"(USRP skipped)")
    else:
        print(f"DUPLEX on B210 {serial}: TX {mc} {fr} @ {txf/1e6:.1f} MHz  +  RX @ {rxf/1e6:.1f} MHz "
              f"(one radio, simultaneous)")
    if raw:
        import shlex
        pt = raw_payload_text(cfg)
        pt_arg = f" --payload-text {shlex.quote(pt)}" if pt else ""
        udp_in_arg = f" --udp-in {raw_udp_in}" if raw_udp_in else ""
        udp_out_arg = f" --udp-out {shlex.quote(raw_udp_out)}" if raw_udp_out else ""
        rx_verbose_arg = " --verbose" if full_stats else ""
        mode_label = "LOOPBACK" if loopback else f"FULL-DUPLEX {serial}"
        sh = (f"'{pybin()}' '{find_helper('rawdata_gen.py')}' --plen 200 --datarate 600000 "
              f"--netrate {int(sr)} --pid 0x100{pt_arg}{udp_in_arg} 2>/dev/null | " + fdcmd +
              f" 3>&1 1>/dev/null {UHD} | '{pybin()}' '{find_helper('rawdata_rx.py')}' --stdin "
              f"--pid 0x100 --plen 200 --rate 600000 --modcod '{mc}' --symrate {int(sr)} "
              f"--mode '{mode_label}'{pt_arg}{udp_out_arg}{rx_verbose_arg}")
        _wait([_popen(["bash","-c",sh], env=media_env())]); return
    # video: file sources are pre-encoded to a CBR cache and looped; live
    # sources (v4l2/udp/pipe) are encoded on the fly so the webcam / network
    # feed reaches the modulator without going through a stale cache. Mirror
    # of cmd_tx's branch at the same name.
    net = net_ts_bps(t["modcod"], fr, sr, t.get("pilots",True)); vb = net*0.82
    pl = cfg.get("payload",{}); src = pl.get("source","file:"+os.path.join(HERE, "media", "sample.mp4"))
    res = pl.get("resolution","auto"); res = auto_resolution(vb) if res=="auto" else res
    fps = int(pl.get("framerate",25))
    if src.startswith("file:"):
        cache = preencode_file(src[5:], res, vb, net, fps)
        prod = f"while :; do cat '{cache}'; done"
    else:
        import shlex as _sx
        enc = (encoder or pl.get("encoder", "hw")).lower()
        print(f"DUPLEX TX (live, encoder={enc}): {src} -> {res}@{vb/1e6:.2f}Mbps")
        ff = build_encode(src, res, vb, net, fps, enc)
        prod = " ".join(_sx.quote(x) for x in ff) + " 2>/tmp/dvbs2_tx.enc.log"
    sink = pl.get("sink","file:/tmp/dvbs2_rx.ts")
    if sink == "display":
        check_display_or_exit()
        net_bps = net_ts_bps(t["modcod"], fr, sr, bool(t.get("pilots", True)))
        cons = (f"| '{pybin()}' '{find_helper('ts_smooth.py')}' --bitrate {int(net_bps)}"
                f" | '{FFPLAY}' -loglevel error -fflags nobuffer -flags low_delay -i -"
                f" 2>/tmp/dvbs2_sink.log")
    elif sink.startswith("udp://"):
        u = sink + ("&" if "?" in sink else "?") + "pkt_size=1316"
        cons = f"| '{FFMPEG}' -hide_banner -loglevel error -fflags +nobuffer -probesize 32 -analyzeduration 0 -f mpegts -i - -c copy -flush_packets 1 -f mpegts '{u}' 2>/tmp/dvbs2_sink.log"
    elif sink.startswith("file:"): cons = f"> '{sink[5:]}'"
    else:                          cons = "> /tmp/dvbs2_rx.ts"
    tee = (f"| '{pybin()}' '{find_helper('ts_tee_stats.py')}' --pid auto "
           f"--modcod '{mc}' --frame '{fr}' --symrate {int(sr)}")
    sh = (prod + " | " + fdcmd +
          f" 3>&1 1>/dev/null {UHD} " + tee + " " + cons)
    if full_stats:
        if loopback:
            with open(rp("dvbs2_dx.radio.log"), "w") as _f:
                _f.write("Actually got clock rate 0 (loopback)\n")
        proc = _popen(["bash","-c", sh], env=media_env())
        # DUPLEX --full-stats: TX-ticker thread + RX poll, routed through one
        # _StatsWriter so a wide terminal renders them as two columns. The
        # writer's t0 is the shared clock for elapsed-second alignment.
        writer = _StatsWriter()
        print(f"  duplex stats — {'two-column' if writer.two_col else 'interleaved (terminal <160 cols)'}; "
              f"\033[1;36m[TX MM:SS]\033[0m on the modulator, \033[1;34m[RX MM:SS]\033[0m on the demod",
              flush=True)
        _stop_tx = threading.Event()
        def _tx_ticker():
            t_mc = mc; t_fr = fr; t_pil = "pilots" if t.get("pilots",True) else "no-pilots"
            t_sr = sr
            t_fps = frame_rate(t_mc, t_fr, t_sr, bool(t.get("pilots",True)))
            t_net = net_ts_bps(t_mc, t_fr, t_sr, bool(t.get("pilots",True)))
            while not _stop_tx.is_set() and proc.poll() is None:
                _stop_tx.wait(1.0)
                if _stop_tx.is_set(): break
                e = int(time.time() - writer.t0)
                writer.tx(e,
                    f"{t_mc} {t_fr} {t_pil} @ {t_sr/1e6:.3f} MSym/s | duplex | "
                    f"{t_fps:.0f} PLFRAME/s, {int(e*t_fps)} sent | link {t_net/1e6:.2f} Mbps")
        tx_thr = threading.Thread(target=_tx_ticker, daemon=True); tx_thr.start()
        try:
            poll_full_stats(MONPORT, cfg, proc, writer=writer, loopback=loopback, skip_radio_wait=True)
        finally:
            _stop_tx.set()
            writer.close()
        return
    _wait([_popen(["bash","-c",sh], env=media_env())])

def _wait(procs):
    try:
        while all(p.poll() is None for p in procs): time.sleep(0.3)
    except KeyboardInterrupt:
        pass
    _kill_all()

def _supervise_rx(label, spawn, monitor=None):
    """Keep a long-running receiver alive across faults. In MODCOD auto-detect the demod
    can fault when the live MODCOD changes mid-stream (FEC reconfiguration); relaunch so
    the link re-acquires the NEW MODCOD after a brief gap. Ctrl-C / SIGTERM stops cleanly
    (no relaunch). Neutral, backend-agnostic messages only."""
    restarts = 0
    while True:
        p = spawn()
        try:
            if monitor: monitor(p)                       # blocks until p exits
            else:
                while p.poll() is None: time.sleep(0.3)
        except KeyboardInterrupt:
            _killgrp(p, signal.SIGINT)
            try: p.wait(timeout=3)
            except BaseException: _killgrp(p, signal.SIGKILL)
            return
        rc = p.poll()                                    # real exit code before we clean up
        _killgrp(p, signal.SIGKILL)                      # ensure pipeline stragglers are down
        try: _PROCS.remove(p)
        except ValueError: pass
        if rc == 0: return                               # clean end (not expected for radio src)
        restarts += 1
        if restarts > 60:
            print("  [link] receiver could not be sustained; stopping."); return
        print(f"  [link] re-acquiring ({label}) after a MODCOD change/fault — restart {restarts}")
        time.sleep(5)                                    # let the radio front-end settle

def main():
    try: sys.stdout.reconfigure(line_buffering=True)   # live progress when piped/redirected
    except Exception: pass
    EPILOG = """\
Valid MODCODs (case-insensitive; '/' or '_' separator are equivalent):
  QPSK   : 1/2  3/5  2/3  3/4  4/5  5/6  8/9  9/10
  8PSK   : 3/5  2/3  3/4  5/6  8/9  9/10
  16APSK : 2/3  3/4  4/5  5/6  8/9  9/10            (extended path; high latency)
  32APSK : 3/4  4/5  5/6  8/9  9/10                 (extended path; high latency)
  RX     : may also use 'auto' for ACM/VCM detection from the PL header.

Symbol rate (-s / --symrate) typical range: 500e3 .. 4e6 (B210 USB caps the upper end).
Frame size  (--frame)        : 'short' (16200) for sub-second latency, 'normal' (64800) for coding gain.
Pilots      (--pilots)       : 'on' (default; tighter carrier tracking) or 'off'.

Run `./dvbs2_TR rates` to print the net bitrate and resolution for the current link.toml.
"""
    ap = argparse.ArgumentParser(
        prog="dvbs2_TR",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=EPILOG)
    ap.add_argument("mode", choices=["check","tx","rx","bench","duplex","rates"])
    ap.add_argument("--config", default=default_config())
    ap.add_argument("--raw", action="store_true", help="raw-data mode for tx/rx (link self-test)")
    ap.add_argument("--full-stats", dest="full_stats", action="store_true",
                    help="rx/duplex: rich per-second readout (SNR(Es/N0), CFO, LDPC iters, FER)")
    ap.add_argument("--loopback", dest="loopback", action="store_true", default=None,
                    help="internal loopback (no radio). Valid for 'duplex' and 'check'. "
                         "Rejected for 'tx', 'rx', 'bench' (half-link modes). "
                         "Overrides [link].loopback in link.toml.")
    ap.add_argument("--raw-udp-in", dest="raw_udp_in", type=int, default=0,
                    help="raw mode (tx/bench/duplex): TX listens on this UDP port and "
                         "injects each datagram as one raw frame payload.")
    ap.add_argument("--raw-udp-out", dest="raw_udp_out", default="",
                    help="raw mode (rx/bench/duplex): RX forwards each recovered payload "
                         "as a UDP datagram to host:port.")
    ap.add_argument("--encoder", choices=["hw","sw"], default=None,
                    help="live video encoder backend for tx/duplex: 'hw' = "
                         "nvv4l2h264enc (Jetson NVENC, default), 'sw' = libx264 "
                         "via ffmpeg. Overrides [payload].encoder in link.toml.")
    ap.add_argument("--secs", type=int, default=20, help="bench duration (s)")
    ap.add_argument("-m", "--modcod", help="override MODCOD (e.g. QPSK3/4, 8PSK2/3, 16APSK2/3; "
                    "or 'auto' on RX = ACM/VCM auto-detect from the PL header). See epilog for the full list.")
    ap.add_argument("-s", "--symrate", type=float,
                    help="override symbol rate (Hz, e.g. 2e6). Typical 500e3 .. 4e6.")
    ap.add_argument("--frame", choices=["short", "normal"], help="override FECFRAME size")
    ap.add_argument("--pilots", choices=["on","off"],
                    help="override PL pilots on/off (default: from link.toml)")
    ap.add_argument("--serial", type=str,
                    help="override B210 serial (e.g. --serial 8000691). "
                         "If unset, the first attached B210 is auto-picked.")
    ap.add_argument("--tx-freq", dest="tx_freq", type=float, help="override TX center freq (Hz)")
    ap.add_argument("--rx-freq", dest="rx_freq", type=float, help="override RX center freq (Hz)")
    ap.add_argument("--tx-gain", dest="tx_gain", type=float, help="override TX gain (dB)")
    ap.add_argument("--rx-gain", dest="rx_gain", type=float, help="override RX gain (dB)")
    a = ap.parse_args()
    cfg = load_toml(a.config)
    if a.loopback is None:
        a.loopback = bool((cfg.get("link") or {}).get("loopback", False))
    def _ov(sec):                                    # CLI overrides the config file
        if sec not in cfg: return
        if a.modcod:  cfg[sec]["modcod"] = a.modcod
        if a.symrate: cfg[sec]["symbol_rate"] = a.symrate
        if a.frame:   cfg[sec]["frame_size"] = a.frame
        if a.pilots:  cfg[sec]["pilots"] = (a.pilots == "on")
    if   a.mode == "tx": _ov("tx")
    elif a.mode == "rx": _ov("rx")
    else:                _ov("tx"); _ov("rx")
    if a.tx_freq: cfg.setdefault("tx", {})["freq_hz"] = a.tx_freq
    if a.rx_freq: cfg.setdefault("rx", {})["freq_hz"] = a.rx_freq
    if a.tx_gain is not None: cfg.setdefault("tx", {})["gain_db"] = a.tx_gain
    if a.rx_gain is not None: cfg.setdefault("rx", {})["gain_db"] = a.rx_gain
    # --serial overrides [tx].device_args, [rx].device_args, and [node].device_args
    # so the chosen B210 is used end-to-end. When --serial is omitted and link.toml
    # has no explicit serial either, the driver picks the first attached B210
    # (cmd_duplex queries UHD; dvbs2-tx/-rx fall back to type=b200).
    if a.serial:
        _devarg = f"type=b200,serial={a.serial}"
        for _sec in ("tx", "rx", "node"):
            cfg.setdefault(_sec, {})["device_args"] = _devarg
    if a.mode in ("tx", "bench", "duplex") and is_auto(cfg.get("tx", {}).get("modcod", "")):
        sys.exit("error: TX needs a concrete MODCOD (e.g. -m QPSK1/2); 'auto' is RX-only (ACM detect).")
    if a.loopback and a.mode in ("tx", "rx", "bench"):
        sys.exit("error: --loopback is end-to-end (TX+RX in one flowgraph); '%s' is a "
                 "half-link mode. Use 'duplex --loopback' instead." % a.mode)
    if   a.mode == "check":  sys.exit(cmd_check(cfg, a.loopback))
    elif a.mode == "rates":  cmd_rates(cfg)
    elif a.mode == "bench":  cmd_bench(cfg, a.secs, raw_udp_in=a.raw_udp_in, raw_udp_out=a.raw_udp_out)
    elif a.mode == "tx":     cmd_tx(cfg, a.raw, a.encoder, raw_udp_in=a.raw_udp_in)
    elif a.mode == "rx":     cmd_rx(cfg, a.raw, a.full_stats, raw_udp_out=a.raw_udp_out)
    elif a.mode == "duplex": cmd_duplex(cfg, a.raw, a.full_stats, a.secs, a.encoder,
                                       loopback=a.loopback,
                                       raw_udp_in=a.raw_udp_in, raw_udp_out=a.raw_udp_out)

if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        pass
    except SystemExit:
        raise                       # intentional, already-neutral exit messages
    except Exception as e:          # never leak a traceback (it can name the backend)
        sys.exit(f"DVBS2_TR error: {type(e).__name__}. Run 'DVBS2_TR check' and verify link.toml.")
